# MateClub - Configuration

# REQUIRED - First admin account (no defaults, must be set)
ADMIN_PSEUDO=your_admin_pseudo
ADMIN_PASSWORD=your_secure_password

# OPTIONAL - Server port (default: 3000)
PORT=3000

# OPTIONAL - Database path (default: /app/data/mateclub.db)
# DATABASE_PATH=/app/data/mateclub.db
